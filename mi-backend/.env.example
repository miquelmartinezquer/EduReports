# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=change_me_with_a_long_random_secret

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=edureports_app
DB_PASSWORD=change_me
DB_NAME=edureports

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# CORS (coma-separated list of allowed origins)
# Example: https://app.tu-dominio.com,https://www.app.tu-dominio.com
CORS_ALLOWED_ORIGINS=https://app.tu-dominio.com

# Session cookie
# For cross-site cookies between different domains, use: none + true
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true
# Optional (only if you need to scope cookie to a parent domain)
# SESSION_COOKIE_DOMAIN=.tu-dominio.com
