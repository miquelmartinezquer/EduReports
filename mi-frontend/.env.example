# Frontend API configuration (Vite)
# Only variables prefixed with VITE_ are exposed to the app.

# Option A: Build URL by protocol + host + port
VITE_API_PROTOCOL=http
VITE_API_HOST=localhost
VITE_API_PORT=3000

# Option B (optional): Full API base URL override.
# If defined, this value takes priority over protocol/host/port.
# VITE_API_BASE_URL=http://localhost:3000
